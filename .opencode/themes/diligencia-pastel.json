{
  "$schema": "https://opencode.ai/theme.json",
  "name": "diligencia-pastel",
  "defs": {
    "bg": "#f5f0ff",
    "panel": "#ebe4f5",
    "element": "#ded5ed",
    "border": "#ccc0e3",
    "borderActive": "#b388ff",
    "primary": "#b388ff",
    "secondary": "#80cbc4",
    "accent": "#ff8a80",
    "error": "#ff5252",
    "warning": "#ffd740",
    "success": "#69f0ae",
    "info": "#82b1ff",
    "text": "#5d4e7a",
    "textMuted": "#a896c4",
    "textDim": "#c5b8db"
  },
  "theme": {
    "primary": { "dark": "primary", "light": "#9c6fff" },
    "secondary": { "dark": "secondary", "light": "#4db6ac" },
    "accent": { "dark": "accent", "light": "#ff6659" },
    "error": { "dark": "error", "light": "error" },
    "warning": { "dark": "warning", "light": "#ffc400" },
    "success": { "dark": "success", "light": "#00e676" },
    "info": { "dark": "info", "light": "#448aff" },
    "text": { "dark": "text", "light": "text" },
    "textMuted": { "dark": "textMuted", "light": "#b39ddb" },
    "background": { "dark": "bg", "light": "#fcfaff" },
    "backgroundPanel": { "dark": "panel", "light": "#f8f4ff" },
    "backgroundElement": { "dark": "element", "light": "#f0eaff" },
    "border": { "dark": "border", "light": "#d8cee8" },
    "borderActive": { "dark": "borderActive", "light": "borderActive" },
    "textLink": { "dark": "info", "light": "info" },
    "textHeading": { "dark": "text", "light": "text" },
    "markdownText": { "dark": "text", "light": "text" },
    "markdownHeading": { "dark": "primary", "light": "#9c6fff" },
    "markdownLink": { "dark": "info", "light": "#448aff" },
    "markdownLinkText": { "dark": "secondary", "light": "#4db6ac" },
    "markdownCode": { "dark": "success", "light": "#00e676" },
    "markdownBlockQuote": { "dark": "textMuted", "light": "#b39ddb" },
    "markdownEmph": { "dark": "warning", "light": "#ffc400" },
    "markdownStrong": { "dark": "accent", "light": "#ff6659" },
    "markdownHorizontalRule": { "dark": "border", "light": "#d8cee8" },
    "markdownListItem": { "dark": "primary", "light": "#9c6fff" },
    "markdownListEnumeration": { "dark": "accent", "light": "#ff6659" },
    "markdownImage": { "dark": "secondary", "light": "#4db6ac" },
    "markdownImageText": { "dark": "error", "light": "error" },
    "markdownCodeBlock": { "dark": "text", "light": "text" },
    "syntaxComment": { "dark": "#a896c4", "light": "#a896c4" },
    "syntaxKeyword": { "dark": "#b388ff", "light": "#9c6fff" },
    "syntaxFunction": { "dark": "primary", "light": "#9c6fff" },
    "syntaxVariable": { "dark": "error", "light": "error" },
    "syntaxString": { "dark": "success", "light": "#00e676" },
    "syntaxNumber": { "dark": "warning", "light": "#ffc400" },
    "syntaxType": { "dark": "secondary", "light": "#4db6ac" },
    "syntaxOperator": { "dark": "primary", "light": "#9c6fff" },
    "syntaxPunctuation": { "dark": "text", "light": "text" }
  }
}
