{
  "$schema": "https://opencode.ai/theme.json",
  "name": "diligencia-oscuro",
  "defs": {
    "bg": "#0f0f12",
    "panel": "#1a1a20",
    "element": "#24242d",
    "border": "#2f2f3a",
    "borderActive": "#ffb000",
    "primary": "#ffb000",
    "secondary": "#4a7cf7",
    "accent": "#ff6b35",
    "error": "#ff3b30",
    "warning": "#ffd60a",
    "success": "#30d158",
    "info": "#5ac8fa",
    "text": "#e5e5e5",
    "textMuted": "#6e6e80",
    "textDim": "#3a3a45"
  },
  "theme": {
    "primary": { "dark": "primary", "light": "#e6a000" },
    "secondary": { "dark": "secondary", "light": "#3a6ae6" },
    "accent": { "dark": "accent", "light": "#e65a2a" },
    "error": { "dark": "error", "light": "error" },
    "warning": { "dark": "warning", "light": "#e6c008" },
    "success": { "dark": "success", "light": "#2ab84a" },
    "info": { "dark": "info", "light": "#48b8e6" },
    "text": { "dark": "text", "light": "#cccccc" },
    "textMuted": { "dark": "textMuted", "light": "#5a5a6c" },
    "background": { "dark": "bg", "light": "#1c1c22" },
    "backgroundPanel": { "dark": "panel", "light": "#26262e" },
    "backgroundElement": { "dark": "element", "light": "#30303a" },
    "border": { "dark": "border", "light": "#3a3a46" },
    "borderActive": { "dark": "borderActive", "light": "#e6a000" },
    "textLink": { "dark": "info", "light": "info" },
    "textHeading": { "dark": "primary", "light": "primary" },
    "markdownText": { "dark": "text", "light": "#cccccc" },
    "markdownHeading": { "dark": "primary", "light": "#e6a000" },
    "markdownLink": { "dark": "info", "light": "info" },
    "markdownLinkText": { "dark": "secondary", "light": "#3a6ae6" },
    "markdownCode": { "dark": "success", "light": "#2ab84a" },
    "markdownBlockQuote": { "dark": "textMuted", "light": "#5a5a6c" },
    "markdownEmph": { "dark": "warning", "light": "#e6c008" },
    "markdownStrong": { "dark": "accent", "light": "#e65a2a" },
    "markdownHorizontalRule": { "dark": "border", "light": "#3a3a46" },
    "markdownListItem": { "dark": "primary", "light": "#e6a000" },
    "markdownListEnumeration": { "dark": "accent", "light": "#e65a2a" },
    "markdownImage": { "dark": "secondary", "light": "#3a6ae6" },
    "markdownImageText": { "dark": "error", "light": "error" },
    "markdownCodeBlock": { "dark": "text", "light": "#cccccc" },
    "syntaxComment": { "dark": "#6e6e80", "light": "#6e6e80" },
    "syntaxKeyword": { "dark": "#ffb000", "light": "#e6a000" },
    "syntaxFunction": { "dark": "primary", "light": "#e6a000" },
    "syntaxVariable": { "dark": "error", "light": "error" },
    "syntaxString": { "dark": "success", "light": "#2ab84a" },
    "syntaxNumber": { "dark": "warning", "light": "#e6c008" },
    "syntaxType": { "dark": "secondary", "light": "#3a6ae6" },
    "syntaxOperator": { "dark": "primary", "light": "#e6a000" },
    "syntaxPunctuation": { "dark": "text", "light": "#cccccc" }
  }
}
