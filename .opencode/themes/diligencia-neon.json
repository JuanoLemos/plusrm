{
  "$schema": "https://opencode.ai/theme.json",
  "name": "diligencia-neon",
  "defs": {
    "bg": "#0a0a0f",
    "panel": "#14141f",
    "element": "#1e1e30",
    "border": "#2a2a45",
    "borderActive": "#00ffc8",
    "primary": "#00ffc8",
    "secondary": "#00d4ff",
    "accent": "#ff00aa",
    "error": "#ff0040",
    "warning": "#ffcc00",
    "success": "#39ff14",
    "info": "#00d4ff",
    "text": "#e0e0ff",
    "textMuted": "#6a6a9a",
    "textDim": "#3a3a5a"
  },
  "theme": {
    "primary": { "dark": "primary", "light": "#00d4aa" },
    "secondary": { "dark": "secondary", "light": "#00b8e6" },
    "accent": { "dark": "accent", "light": "#e60099" },
    "error": { "dark": "error", "light": "error" },
    "warning": { "dark": "warning", "light": "#e6b800" },
    "success": { "dark": "success", "light": "#30d910" },
    "info": { "dark": "info", "light": "info" },
    "text": { "dark": "text", "light": "#b0b0d0" },
    "textMuted": { "dark": "textMuted", "light": "#5a5a7a" },
    "background": { "dark": "bg", "light": "#1a1a2e" },
    "backgroundPanel": { "dark": "panel", "light": "#22223a" },
    "backgroundElement": { "dark": "element", "light": "#2a2a44" },
    "border": { "dark": "border", "light": "#353555" },
    "borderActive": { "dark": "borderActive", "light": "#00e6b0" },
    "textLink": { "dark": "info", "light": "info" },
    "textHeading": { "dark": "primary", "light": "#00e6b0" },
    "markdownText": { "dark": "text", "light": "#b0b0d0" },
    "markdownHeading": { "dark": "primary", "light": "primary" },
    "markdownLink": { "dark": "info", "light": "info" },
    "markdownLinkText": { "dark": "secondary", "light": "#00b8e6" },
    "markdownCode": { "dark": "success", "light": "#30d910" },
    "markdownBlockQuote": { "dark": "textMuted", "light": "#5a5a7a" },
    "markdownEmph": { "dark": "warning", "light": "#e6b800" },
    "markdownStrong": { "dark": "accent", "light": "#e60099" },
    "markdownHorizontalRule": { "dark": "border", "light": "#353555" },
    "markdownListItem": { "dark": "primary", "light": "primary" },
    "markdownListEnumeration": { "dark": "accent", "light": "#e60099" },
    "markdownImage": { "dark": "secondary", "light": "#00b8e6" },
    "markdownImageText": { "dark": "error", "light": "error" },
    "markdownCodeBlock": { "dark": "text", "light": "#b0b0d0" },
    "syntaxComment": { "dark": "#6a6a9a", "light": "#6a6a9a" },
    "syntaxKeyword": { "dark": "#ff00aa", "light": "#e60099" },
    "syntaxFunction": { "dark": "primary", "light": "#00d4aa" },
    "syntaxVariable": { "dark": "error", "light": "error" },
    "syntaxString": { "dark": "success", "light": "#30d910" },
    "syntaxNumber": { "dark": "warning", "light": "#e6b800" },
    "syntaxType": { "dark": "secondary", "light": "#00b8e6" },
    "syntaxOperator": { "dark": "primary", "light": "#00d4aa" },
    "syntaxPunctuation": { "dark": "text", "light": "#b0b0d0" }
  }
}
