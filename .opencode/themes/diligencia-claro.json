{
  "$schema": "https://opencode.ai/theme.json",
  "name": "diligencia-claro",
  "defs": {
    "bg": "#faf8f5",
    "panel": "#f0ece4",
    "element": "#e5dfd3",
    "border": "#d5cdc0",
    "borderActive": "#4a7cf7",
    "primary": "#4a7cf7",
    "secondary": "#6ea8fe",
    "accent": "#e8893a",
    "error": "#d6393a",
    "warning": "#d4a72c",
    "success": "#2b9a4a",
    "info": "#4a7cf7",
    "text": "#3d3d3d",
    "textMuted": "#9b9b9b",
    "textDim": "#c5c5c5"
  },
  "theme": {
    "primary": { "dark": "primary", "light": "primary" },
    "secondary": { "dark": "secondary", "light": "secondary" },
    "accent": { "dark": "accent", "light": "accent" },
    "error": { "dark": "error", "light": "error" },
    "warning": { "dark": "warning", "light": "warning" },
    "success": { "dark": "success", "light": "success" },
    "info": { "dark": "info", "light": "info" },
    "text": { "dark": "text", "light": "text" },
    "textMuted": { "dark": "textMuted", "light": "#b0b0b0" },
    "background": { "dark": "bg", "light": "#ffffff" },
    "backgroundPanel": { "dark": "panel", "light": "#fdfcfa" },
    "backgroundElement": { "dark": "element", "light": "#f5f2ee" },
    "border": { "dark": "border", "light": "#e8e4df" },
    "borderActive": { "dark": "borderActive", "light": "borderActive" },
    "textLink": { "dark": "info", "light": "info" },
    "textHeading": { "dark": "text", "light": "text" },
    "diffAdded": { "dark": "success", "light": "#1a7a37" },
    "diffRemoved": { "dark": "error", "light": "#b02a2b" },
    "diffContext": { "dark": "textMuted", "light": "#9b9b9b" },
    "diffAddedBg": { "dark": "#1e3a24", "light": "#e0f5e4" },
    "diffRemovedBg": { "dark": "#3a1e22", "light": "#fce4e4" },
    "diffContextBg": { "dark": "panel", "light": "#faf8f5" },
    "diffHighlightAdded": { "dark": "success", "light": "#1a7a37" },
    "diffHighlightRemoved": { "dark": "error", "light": "#b02a2b" },
    "diffAddedLineNumberBg": { "dark": "#1e3a24", "light": "#c8ebd0" },
    "diffRemovedLineNumberBg": { "dark": "#3a1e22", "light": "#fad0d0" },
    "diffLineNumber": { "dark": "#9b9b9b", "light": "#b0b0b0" },
    "diffHunkHeader": { "dark": "panel", "light": "#f0ece4" },
    "markdownText": { "dark": "text", "light": "text" },
    "markdownHeading": { "dark": "primary", "light": "primary" },
    "markdownLink": { "dark": "info", "light": "info" },
    "markdownLinkText": { "dark": "secondary", "light": "secondary" },
    "markdownCode": { "dark": "success", "light": "success" },
    "markdownBlockQuote": { "dark": "textMuted", "light": "textMuted" },
    "markdownEmph": { "dark": "warning", "light": "warning" },
    "markdownStrong": { "dark": "accent", "light": "accent" },
    "markdownHorizontalRule": { "dark": "border", "light": "border" },
    "markdownListItem": { "dark": "primary", "light": "primary" },
    "markdownListEnumeration": { "dark": "accent", "light": "accent" },
    "markdownImage": { "dark": "secondary", "light": "secondary" },
    "markdownImageText": { "dark": "error", "light": "error" },
    "markdownCodeBlock": { "dark": "text", "light": "text" },
    "syntaxComment": { "dark": "#8a8a8a", "light": "#8a8a8a" },
    "syntaxKeyword": { "dark": "#6c63ff", "light": "#6c63ff" },
    "syntaxFunction": { "dark": "primary", "light": "primary" },
    "syntaxVariable": { "dark": "error", "light": "error" },
    "syntaxString": { "dark": "success", "light": "success" },
    "syntaxNumber": { "dark": "warning", "light": "warning" },
    "syntaxType": { "dark": "secondary", "light": "secondary" },
    "syntaxOperator": { "dark": "primary", "light": "primary" },
    "syntaxPunctuation": { "dark": "text", "light": "text" }
  }
}
